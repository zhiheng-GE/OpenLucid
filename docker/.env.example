# ============================================================
# OpenLucid Configuration
# Copy this file to .env and customize as needed.
# ============================================================

# ── Database ──
# ⚠️ If upgrading from OpenInsight: these MUST match the credentials your
#    PostgreSQL volume was created with. If you see "password authentication
#    failed" on startup, update these to match, or delete the DB volume
#    (docker compose down -v) and start fresh.
DB_USER=openlucid
DB_PASSWORD=openlucid          # ⚠️ Change in production!
DB_NAME=openlucid

# ── Application ──
APP_PORT=80                       # Port exposed on host
SECRET_KEY=change-me-in-production  # ⚠️ Change this! Used for JWT
LOG_LEVEL=INFO                    # DEBUG / INFO / WARNING / ERROR

# ── Email (optional — leave empty to disable password reset emails) ──
# MAIL_TYPE=resend                   # "resend" or "smtp"; auto-detected if empty
# MAIL_FROM=no-reply@yourdomain.com
# RESEND_API_KEY=re_xxx
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# APP_URL=http://localhost

# ── In-app feedback (zero-config; optional override) ──
# The in-app feedback button is ALWAYS visible. By default it opens a
# prefilled GitHub Issue at FEEDBACK_FALLBACK_URL when the user submits.
# If you want feedback to be emailed to YOUR inbox instead (e.g. you run
# OpenLucid for your team and want to collect their feedback), set
# FEEDBACK_TO_EMAIL — this requires MAIL_TYPE/RESEND/SMTP to be configured too.
# FEEDBACK_TO_EMAIL=you@yourdomain.com
# FEEDBACK_FALLBACK_URL=https://github.com/agidesigner/OpenLucid/issues/new

# ── CORS (optional — comma-separated origins, or * for all) ──
# CORS_ORIGINS=*

# ── LLM is configured in the web UI (Settings page), not here ──
